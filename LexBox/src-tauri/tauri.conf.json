{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RedBox",
  "version": "0.1.0",
  "identifier": "com.redconvert.redbox",
  "build": {
    "beforeDevCommand": "pnpm tauri:before-dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RedBox",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.redbox/**",
          "$HOME/.redconvert/**",
          "$HOME/.redconvert.migrated-*/**",
          "$APPDATA/RedBox/**",
          "$HOME/Library/Application Support/RedBox/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "resources": [
      "resources/knowledge-api-guide.html",
      "../builtin-skills"
    ],
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
